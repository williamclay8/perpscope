{
  "name": "perpscope",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Read-only Percolator risk cockpit and terminal adapter kit.",
  "repository": {
    "type": "git",
    "url": "https://github.com/williamclay8/perpscope"
  },
  "workspaces": [
    "packages/percolator-adapter"
  ],
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "decoder:start": "node scripts/percolator-decoder-worker.mjs",
    "start": "node scripts/serve.mjs",
    "check": "node scripts/check-static.mjs && npm test && npm run build",
    "test": "node --test"
  },
  "keywords": [
    "solana",
    "perps",
    "percolator",
    "risk",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@percolatorct/sdk": "2.0.9"
  }
}
