{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://williamclay8.github.io/perpscope/schemas/perpscope-snapshot.schema.json",
  "title": "PerpScope Snapshot",
  "type": "object",
  "required": ["markets"],
  "additionalProperties": true,
  "properties": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string" },
        "mode": { "const": "read-only" },
        "generatedAt": { "type": "string" }
      }
    },
    "cluster": { "type": "string" },
    "currentSlot": { "type": "number" },
    "markets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "base": { "type": "string" },
          "quote": { "type": "string" },
          "slab": { "type": "string" },
          "program": { "type": "string" },
          "header": { "type": "object" },
          "config": { "type": "object" },
          "oracle": { "type": "object" },
          "engine": { "type": "object" },
          "account": { "type": "object" },
          "execution": { "type": "object" }
        }
      }
    }
  }
}
